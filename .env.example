# ==============================================================================
# DATABASE CONFIGURATION
# Backend MUST connect through PgBouncer or Supavisor (Pooling Mode: Transaction)
# Typical PgBouncer Transaction Mode port is 6543 (or standard Postgres 5432 redirected)
# ==============================================================================
BE_DATABASE_URL=postgresql://postgres:Passwordstr!2@localhost:5432/trading_db?sslmode=disable

# ==============================================================================
# BACKEND CONFIGURATION (BE_ prefix)
# ==============================================================================
BE_PORT=3082
BE_REDIS_URL=redis://localhost:6379
BE_JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_bytes_long
BE_SENTRY_DSN=http://b2fe7ce9f73b45678acf74e48d0e2f96@glitchtip:8000/1
BE_CORS_ALLOWED_ORIGINS=http://localhost,http://192.168.1.20,http://localhost:8082,http://127.0.0.1:8082,http://localhost:5173,http://127.0.0.1:5173


# ==============================================================================
# FRONTEND CONFIGURATION (FE_ prefix)
# ==============================================================================
FE_VITE_API_URL=http://localhost:3082
FE_APP_TITLE="Trading Platform"
FE_PORT=8082
FE_BASE_URL=/trading/public/
FE_VITE_SENTRY_DSN=http://b2fe7ce9f73b45678acf74e48d0e2f96@localhost:8000/1

# ==============================================================================
# DOCUMENTATION CONFIGURATION (DOCS_ prefix)
# ==============================================================================
DOCS_PORT=4000
